# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wechat_shop
DB_USER=shopuser
DB_PASSWORD=your_secure_database_password

# JWT Configuration
JWT_SECRET=your_very_long_random_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_PATH=./uploads/products
MAX_FILE_SIZE=2097152

# Logging Configuration
LOG_LEVEL=info
LOG_PATH=./logs

# WeChat Mini Program Configuration
WECHAT_APPID=wx06e38f82f0bafd80
WECHAT_SECRET=your-wechat-mini-program-secret

# ========================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# ========================================

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all values with your actual configuration
# 3. Keep .env in .gitignore and never commit it
