<view class="delivery-page">
  <view class="page-header">
    <text class="page-title">配送区域设置</text>
    <t-button size="small" theme="primary" icon="add" bind:tap="onAdd">新增区域</t-button>
  </view>

  <view class="area-list">
    <view class="area-card" wx:for="{{areaList}}" wx:key="id">
      <view class="area-header">
        <text class="area-name">{{item.areaName}}</text>
        <view class="area-actions">
          <t-button size="extra-small" variant="outline" data-id="{{item.id}}" bind:tap="onEdit">编辑</t-button>
          <t-button size="extra-small" theme="danger" variant="outline" data-id="{{item.id}}" bind:tap="onDelete">删除</t-button>
        </view>
      </view>
      <view class="area-desc">{{item.description}}</view>
      <view class="area-fees">
        <view class="fee-item">
          <text class="fee-label">基础运费</text>
          <text class="fee-value">¥{{item.baseFee / 100}}</text>
        </view>
        <view class="fee-item">
          <text class="fee-label">免运费门槛</text>
          <text class="fee-value">¥{{item.freeThreshold / 100}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{areaList.length === 0}}">
    <text>暂无配送区域，请点击"新增区域"添加</text>
  </view>

  <!-- 编辑弹窗 -->
  <t-popup visible="{{showEditDialog}}" placement="bottom" bind:visible-change="onCancelEdit">
    <view class="edit-panel">
      <view class="edit-header">
        <text class="edit-title">{{isAdd ? '新增配送区域' : '编辑配送区域'}}</text>
      </view>
      <view class="edit-form">
        <view class="form-item">
          <text class="form-label">区域名称</text>
          <input class="form-input" placeholder="如：同城配送" value="{{formData.areaName}}" data-field="areaName" bindinput="onFormInput" />
        </view>
        <view class="form-item">
          <text class="form-label">描述</text>
          <input class="form-input" placeholder="区域描述" value="{{formData.description}}" data-field="description" bindinput="onFormInput" />
        </view>
        <view class="form-item">
          <text class="form-label">基础运费(元)</text>
          <input class="form-input" type="digit" placeholder="如：5" value="{{formData.baseFee}}" data-field="baseFee" bindinput="onFormInput" />
        </view>
        <view class="form-item">
          <text class="form-label">免运费门槛(元)</text>
          <input class="form-input" type="digit" placeholder="如：99" value="{{formData.freeThreshold}}" data-field="freeThreshold" bindinput="onFormInput" />
        </view>
      </view>
      <view class="edit-actions">
        <t-button block variant="outline" bind:tap="onCancelEdit">取消</t-button>
        <t-button block theme="primary" bind:tap="onSave">保存</t-button>
      </view>
    </view>
  </t-popup>
</view>
