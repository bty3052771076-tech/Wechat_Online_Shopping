.user-manage-page {
  padding-bottom: 20rpx;
}

.search-bar {
  background: #fff;
  padding: 10rpx 0;
}

.user-list {
  padding: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nick-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.remark-tag {
  font-size: 20rpx;
  color: #0052d9;
  background: #e8f3ff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.phone {
  font-size: 26rpx;
  color: #666;
}

.user-stats {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.divider {
  margin: 0 12rpx;
  color: #ddd;
}

.register-time {
  font-size: 22rpx;
  color: #bbb;
}

.arrow-icon {
  flex-shrink: 0;
  margin-left: 10rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
