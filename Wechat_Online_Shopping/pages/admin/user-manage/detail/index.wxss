.user-detail-page {
  padding: 20rpx;
}

.profile-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
}

.profile-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nick-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.remark-area {
  padding: 16rpx 24rpx 24rpx;
}

.remark-text {
  font-size: 28rpx;
  color: #666;
}

.remark-edit {
  padding: 16rpx 24rpx 24rpx;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.order-history {
  padding: 16rpx 24rpx 24rpx;
}

.order-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-row:last-child {
  border-bottom: none;
}

.order-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-no {
  font-size: 26rpx;
  color: #333;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

.order-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.order-amount {
  font-size: 28rpx;
  color: #fa4126;
  font-weight: bold;
}

.order-status {
  font-size: 22rpx;
  color: #999;
}

.empty-orders {
  padding: 40rpx 24rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
