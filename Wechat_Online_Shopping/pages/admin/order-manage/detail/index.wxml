<view class="order-detail-page" wx:if="{{order}}">
  <!-- 状态区 -->
  <view class="status-section">
    <text class="status-text">{{order.statusName}}</text>
    <t-tag wx:if="{{order.status === 10}}" theme="warning">需发货</t-tag>
  </view>

  <!-- 收货信息 -->
  <view class="section">
    <view class="section-title">收货信息</view>
    <t-cell-group>
      <t-cell title="收货人" note="{{order.userName}}" />
      <t-cell title="手机号" note="{{order.phone}}" />
      <t-cell title="地址" note="{{order.address}}" />
    </t-cell-group>
  </view>

  <!-- 商品列表 -->
  <view class="section">
    <view class="section-title">商品信息</view>
    <view class="goods-item" wx:for="{{order.goodsList}}" wx:key="name">
      <t-image src="{{item.image}}" width="160rpx" height="160rpx" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-spec">{{item.spec}}</text>
        <view class="goods-price-row">
          <text class="goods-price">¥{{item.price / 100}}</text>
          <text class="goods-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="section">
    <view class="section-title">订单信息</view>
    <t-cell-group>
      <t-cell title="订单号" note="{{order.orderNo}}" />
      <t-cell title="下单时间" note="{{order.createTime}}" />
      <t-cell title="商品总额" note="¥{{order.totalAmount / 100}}" />
      <t-cell title="运费" note="¥{{order.freightFee / 100}}" />
      <t-cell title="订单备注" note="{{order.remark || '无'}}" />
    </t-cell-group>
  </view>

  <!-- 物流信息（已发货时显示） -->
  <view class="section" wx:if="{{order.expressCompany}}">
    <view class="section-title">物流信息</view>
    <t-cell-group>
      <t-cell title="快递公司" note="{{order.expressCompany}}" />
      <t-cell title="运单号" note="{{order.expressNo}}" />
    </t-cell-group>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{order.status === 10}}">
    <t-button theme="primary" block bind:tap="goShip">立即发货</t-button>
  </view>
</view>

<view class="empty-tip" wx:if="{{!order}}">
  <text>订单不存在</text>
</view>
