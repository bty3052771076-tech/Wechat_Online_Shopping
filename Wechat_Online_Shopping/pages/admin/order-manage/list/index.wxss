.order-manage-page { background: #f5f5f5; min-height: 100vh; }
.filter-toggle { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; background: #fff; font-size: 24rpx; color: #666; border-bottom: 1rpx solid #eee; }
.filter-panel { background: #fff; padding: 16rpx 0; margin-bottom: 16rpx; }
.filter-actions { display: flex; gap: 16rpx; justify-content: center; padding: 16rpx; }
.date-filter { display: flex; align-items: center; padding: 16rpx 24rpx; gap: 12rpx; }
.date-label { font-size: 28rpx; color: #333; width: 140rpx; flex-shrink: 0; }
.date-pick { font-size: 26rpx; color: #333; background: #f5f5f5; padding: 12rpx 20rpx; border-radius: 8rpx; min-width: 180rpx; text-align: center; }
.date-sep { font-size: 26rpx; color: #999; }
.order-list { padding: 0 24rpx; }
.order-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.order-no { font-size: 24rpx; color: #666; }
.order-status { font-size: 24rpx; color: #0052d9; font-weight: bold; }
.status-ship { color: #e53935; }
.order-user { font-size: 22rpx; color: #999; margin-bottom: 8rpx; display: flex; justify-content: space-between; }
.order-time { font-size: 22rpx; color: #bbb; }
.order-goods { font-size: 24rpx; color: #333; margin-bottom: 4rpx; }
.order-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid #f0f0f0; }
.order-amount { font-size: 30rpx; color: #e53935; font-weight: bold; }
.order-actions { display: flex; gap: 12rpx; }
.empty-tip { text-align: center; padding: 120rpx 0; color: #999; }
