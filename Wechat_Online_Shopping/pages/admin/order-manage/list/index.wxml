<view class="order-manage-page">
  <view class="tab-bar">
    <t-tabs defaultValue="{{-1}}" bind:change="onTabChange" space-evenly="{{false}}">
      <t-tab-panel wx:for="{{statusTabs}}" wx:key="key" label="{{item.text}}" value="{{item.key}}" />
    </t-tabs>
  </view>

  <view class="filter-toggle" bind:tap="toggleFilter">
    <t-icon name="filter" size="32rpx" /> <text>筛选</text>
  </view>

  <view class="filter-panel" wx:if="{{showFilter}}">
    <t-input label="订单号" placeholder="输入订单号" value="{{filters.orderNo}}" data-field="orderNo" bind:change="onFilterInput" />
    <t-input label="收货人" placeholder="输入收货人姓名" value="{{filters.userName}}" data-field="userName" bind:change="onFilterInput" />
    <t-input label="手机号" placeholder="输入手机号" value="{{filters.phone}}" data-field="phone" bind:change="onFilterInput" />
    <view class="date-filter">
      <text class="date-label">下单时间</text>
      <picker mode="date" value="{{filters.startDate}}" bindchange="onStartDateChange">
        <view class="date-pick">{{filters.startDate || '起始日期'}}</view>
      </picker>
      <text class="date-sep">至</text>
      <picker mode="date" value="{{filters.endDate}}" bindchange="onEndDateChange">
        <view class="date-pick">{{filters.endDate || '结束日期'}}</view>
      </picker>
    </view>
    <view class="filter-actions">
      <t-button size="small" bind:tap="onClearFilter">清除</t-button>
      <t-button size="small" theme="primary" bind:tap="onSearch">查询</t-button>
    </view>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orderList}}" wx:key="orderNo">
      <view class="order-header">
        <text class="order-no">{{item.orderNo}}</text>
        <text class="order-status {{item.status === 10 ? 'status-ship' : ''}}">{{item.statusName}}</text>
      </view>
      <view class="order-user">
        <text>{{item.userName}} | {{item.phone}}</text>
        <text class="order-time">{{item.createTime}}</text>
      </view>
      <view class="order-goods" wx:for="{{item.goodsList}}" wx:for-item="goods" wx:key="name">
        <text>{{goods.name}} x{{goods.quantity}}</text>
      </view>
      <view class="order-footer">
        <text class="order-amount">¥{{item.totalAmount / 100}}</text>
        <view class="order-actions">
          <t-button size="extra-small" variant="outline" data-orderno="{{item.orderNo}}" bind:tap="goDetail">详情</t-button>
          <t-button wx:if="{{item.status === 10}}" size="extra-small" theme="primary" data-orderno="{{item.orderNo}}" bind:tap="goShip">发货</t-button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{orderList.length === 0}}">
    <text>暂无订单数据</text>
  </view>
</view>
