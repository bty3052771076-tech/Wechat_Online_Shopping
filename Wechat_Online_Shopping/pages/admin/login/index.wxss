.admin-login-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  margin-bottom: 60rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
}

.login-form {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.login-btn-group {
  margin-top: 48rpx;
}

.login-tip {
  text-align: center;
  margin-top: 24rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #bbb;
}
