.after-sale-page {
  padding-bottom: 20rpx;
}

.tab-bar {
  background: #fff;
  margin-bottom: 20rpx;
}

.list {
  padding: 0 20rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.as-id {
  font-size: 26rpx;
  color: #666;
}

.as-status {
  font-size: 24rpx;
  color: #999;
}

.as-status.status-pending {
  color: #e34d59;
  font-weight: bold;
}

.card-body {
  display: flex;
  padding: 20rpx 24rpx;
}

.card-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.as-type {
  font-size: 24rpx;
  color: #0052d9;
}

.as-reason {
  font-size: 24rpx;
  color: #999;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.user-info {
  font-size: 24rpx;
  color: #999;
}

.refund-amount {
  font-size: 28rpx;
  color: #fa4126;
  font-weight: bold;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
