.as-detail-page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.status-section {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.as-type {
  font-size: 24rpx;
  color: #0052d9;
  background: #e8f3ff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 24rpx 24rpx 0;
}

.goods-row {
  display: flex;
  padding: 20rpx 24rpx;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
}

.refund-amount {
  font-size: 28rpx;
  color: #fa4126;
  font-weight: bold;
}

.evidence-list {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 24rpx 24rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
