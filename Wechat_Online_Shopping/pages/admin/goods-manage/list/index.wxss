.goods-manage-page { background: #f5f5f5; min-height: 100vh; }
.search-bar { background: #fff; padding: 8rpx 0; }
.action-bar { padding: 16rpx 24rpx; display: flex; justify-content: flex-end; }
.goods-list { padding: 0 24rpx; }
.goods-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; flex-direction: column; gap: 16rpx; }
.goods-image { width: 160rpx; height: 160rpx; border-radius: 8rpx; flex-shrink: 0; }
.goods-info { flex: 1; }
.goods-name { font-size: 28rpx; font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.goods-meta { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.goods-spec { font-size: 22rpx; color: #666; display: block; margin-bottom: 8rpx; }
.goods-bottom { display: flex; justify-content: space-between; align-items: center; }
.goods-price { font-size: 30rpx; color: #e53935; font-weight: bold; }
.goods-stock { font-size: 22rpx; color: #999; }
.goods-actions { display: flex; gap: 12rpx; justify-content: flex-end; }
.empty-tip { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
