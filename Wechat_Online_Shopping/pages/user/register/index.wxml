<view class="register-page">
  <view class="register-header">
    <text class="register-title">注册账号</text>
    <text class="register-subtitle">填写以下信息完成注册</text>
  </view>

  <view class="register-form">
    <t-input
      label="用户名"
      placeholder="请输入用户名"
      value="{{username}}"
      data-field="username"
      bind:change="onInput"
    />
    <t-input
      label="密码"
      placeholder="请设定密码（至少6位）"
      type="password"
      value="{{password}}"
      data-field="password"
      bind:change="onInput"
    />
    <t-input
      label="确认密码"
      placeholder="请再次输入密码"
      type="password"
      value="{{confirmPassword}}"
      data-field="confirmPassword"
      bind:change="onInput"
    />
    <view class="form-section-title">绑定手机号或邮箱（至少填写一项）</view>
    <t-input
      label="手机号"
      placeholder="请输入手机号"
      type="number"
      value="{{phoneNumber}}"
      data-field="phoneNumber"
      bind:change="onInput"
    />
    <t-input
      label="邮箱"
      placeholder="请输入电子邮箱"
      value="{{email}}"
      data-field="email"
      bind:change="onInput"
    />

    <view class="register-btn-group">
      <t-button theme="primary" block loading="{{loading}}" bind:tap="handleRegister">
        注册
      </t-button>
    </view>

    <view class="register-footer">
      <text class="login-link" bind:tap="goLogin">已有账号？去登录</text>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
